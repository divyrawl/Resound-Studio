# ============================================================
# Resound Studio - Environment Configuration (Production)
# ============================================================

# --- API Security ---
# Comma-separated list of allowed origins for CORS.
# For production, set this to your frontend URL (e.g., https://resound.studio)
ALLOWED_ORIGINS=http://localhost:3000

# Optional: Add a master API key for protected endpoints
RESOUND_API_KEY=

# --- Backend Configuration ---
IS_DOCKER=false
DATABASE_URL=sqlite:///./data/resound.db
HF_HOME=./data/models

# --- Frontend Configuration ---
# Must be accessible by the browser. 
# If running in Docker locally, use http://localhost:8000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# --- Model Settings ---
# Maximum number of models to keep in VRAM cache simultaneously
MAX_LOADED_MODELS=2

# Default device (auto | cuda | cpu | mps)
TTS_DEVICE=auto
